# Google Maps Platform - 3D Tiles API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Cesium Ion Access Token
CESIUM_ION_TOKEN=your_cesium_ion_token

# OpenSky Network - OAuth2 Client Credentials (v2 API)
OPENSKY_CLIENT_ID=your_opensky_client_id
OPENSKY_CLIENT_SECRET=your_opensky_client_secret
# Legacy basic-auth (kept for fallback)
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# ADS-B Exchange (RapidAPI) - Phase 3
ADSBX_API_KEY=

# AISStream - real-time AIS maritime WebSocket
AISSTREAM_API_KEY=your_aisstream_api_key

# Database
DATABASE_URL=postgresql://eagle:eagle@localhost:5432/eagleeye
REDIS_URL=redis://localhost:6379

# Server
SERVER_PORT=3001
CLIENT_PORT=5173
